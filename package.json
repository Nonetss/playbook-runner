{
  "name": "none.stack",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/bun": "^1.3.4",
      "hono": "^4.8.2",
      "@orpc/server": "^1.13.14",
      "@orpc/openapi": "^1.13.14",
      "@orpc/zod": "^1.13.14",
      "better-auth": "1.6.22",
      "@orpc/client": "^1.13.14",
      "@orpc/tanstack-query": "^1.13.14"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "format": "biome check --write --linter-enabled=false .",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @none.stack/db db:push",
    "db:studio": "turbo -F @none.stack/db db:studio",
    "db:generate": "turbo -F @none.stack/db db:generate",
    "db:migrate": "turbo -F @none.stack/db db:migrate",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "check": "biome check --write ."
  },
  "dependencies": {
    "@better-auth/core": "^1.6.22",
    "@none.stack/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@none.stack/config": "workspace:*",
    "@types/bun": "catalog:",
    "turbo": "^2.9.16",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.14"
}
