{
  "name": "playbook-runner",
  "version": "0.2.0",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/bun": "^1.3.4",
      "hono": "^4.8.2",
      "@orpc/server": "^1.13.14",
      "@orpc/openapi": "^1.13.14",
      "@orpc/zod": "^1.13.14",
      "better-auth": "1.6.22",
      "@orpc/client": "^1.13.14",
      "@orpc/tanstack-query": "^1.13.14"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "format": "biome check --write --linter-enabled=false .",
    "dev:frontend": "turbo -F frontend dev",
    "dev:backend": "turbo -F backend dev",
    "db:push": "turbo -F @playbook-runner/db db:push",
    "db:pull": "turbo -F @playbook-runner/db db:pull",
    "db:studio": "turbo -F @playbook-runner/db db:studio",
    "db:generate": "turbo -F @playbook-runner/db db:generate",
    "db:migrate": "turbo -F @playbook-runner/db db:migrate",
    "db:seed": "turbo -F backend db:seed",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "test:e2e": "turbo -F frontend test:e2e",
    "test:e2e:ui": "turbo -F frontend test:e2e:ui",
    "test:e2e:headed": "turbo -F frontend test:e2e:headed",
    "check": "biome check --write ."
  },
  "dependencies": {
    "@better-auth/core": "^1.6.22",
    "@playbook-runner/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@playbook-runner/config": "workspace:*",
    "@types/bun": "catalog:",
    "turbo": "^2.9.16",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.14"
}
