# ─────────────────────────────────────────────────────────────────────────────
# Production environment consumed by `compose.prod.yml`.
#
#   cp .env.example .env   # then replace every CHANGE_ME
#
# Image refs default to the Gitea registry paths the CI
# (.github/workflows/docker-build.yml) pushes to. Override the *_IMAGE or
# *_TAG variables to pin a specific build (e.g. ANSIBLE_IMAGE_TAG=v0.0.4).
# ─────────────────────────────────────────────────────────────────────────────

# ── Image registry ──────────────────────────────────────────────────────────
ANSIBLE_IMAGE=gitea.sanjuandediosmalaga.es/amoreno80z/playbook.runner-ansible
ANSIBLE_IMAGE_TAG=latest

BACKEND_IMAGE=gitea.sanjuandediosmalaga.es/amoreno80z/playbook.runner-backend
BACKEND_IMAGE_TAG=latest

FRONTEND_IMAGE=gitea.sanjuandediosmalaga.es/amoreno80z/playbook.runner-frontend
FRONTEND_IMAGE_TAG=latest

# ── Public host ─────────────────────────────────────────────────────────────
# Port the frontend (Caddy → Astro SSR) is published on.
FRONTEND_PORT=4321

# Origin the browser hits — used for build-time absolute URLs.
PUBLIC_SERVER_URL=http://localhost:4321

# Origin the backend allows via CORS — must match PUBLIC_SERVER_URL.
CORS_ORIGIN=http://localhost:4321

# ── Backend (Bun + Hono + Better Auth + Drizzle) ────────────────────────────
# PostgreSQL is expected to be provisioned externally (managed DB, sidecar,
# k8s service …). compose.prod.yml does not include it.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/ansible

# Generate with:  openssl rand -base64 48
BETTER_AUTH_SECRET=CHANGE_ME_at_least_32_chars_long_random_string

# "0" disables the in-process cron that fires scheduled playbooks.
JOB_SCHEDULER_ENABLED=1

# ── Ansible (FastAPI + ansible-runner) ──────────────────────────────────────
ANSIBLE_USER=ansible
ANSIBLE_BECOME_USER=root
ANSIBLE_HOST_KEY_CHECKING=false

# ── Service-to-service auth ─────────────────────────────────────────────────
# Shared secret that the backend sends on internal /api/run/* calls and the
# ansible service compares against. Rotate together.
INTERNAL_TOKEN=CHANGE_ME_share_with_apps_ansible_env
