# ─────────────────────────────────────────────────────────────────────────────
# Production environment consumed by `compose.prod.yml`.
#
#   cp .env.example .env   # then replace every CHANGE_ME
#
# Image refs default to the GitHub Container Registry paths the CI
# (.github/workflows/docker-build.yml) pushes to. Override the *_IMAGE or
# *_TAG variables to pin a specific build (e.g. ANSIBLE_IMAGE_TAG=v0.0.4).
# ─────────────────────────────────────────────────────────────────────────────

# ── Image registry ──────────────────────────────────────────────────────────
# Image refs are hardcoded in compose.prod.yml (ghcr.io/nonetss/playbook-runner-*).
# Only the tag is overridable here, useful to pin a release (e.g. v0.0.5).
ANSIBLE_IMAGE_TAG=latest
BACKEND_IMAGE_TAG=latest
FRONTEND_IMAGE_TAG=latest

# ── Public host ─────────────────────────────────────────────────────────────
# Port the frontend (Caddy → Astro SSR) is published on.
FRONTEND_PORT=4321

# Origin the backend allows via CORS — must match the public frontend URL.
CORS_ORIGIN=http://localhost:4321

# ── PostgreSQL (compose.prod.yml only) ──────────────────────────────────────
# Credentials for the bundled postgres service. Ignored if you point
# DATABASE_URL at an external managed DB and remove the postgres service
# from compose.prod.yml.
POSTGRES_DB=playbook_runner
POSTGRES_USER=playbook_runner
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password

# ── Backend (Bun + Hono + Better Auth + Drizzle) ────────────────────────────
# In compose.prod.yml this resolves to the bundled postgres service via
# service-name DNS. For external DBs, point this at the managed host.
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# Public base URL Better Auth uses for callbacks and to build redirect URIs.
# Must be reachable by the user's browser, so it points at the frontend port.
# Change to your real domain in production (e.g. https://playbook.example.com).
BETTER_AUTH_URL=http://localhost:4321

# Generate with:  openssl rand -base64 48
BETTER_AUTH_SECRET=CHANGE_ME_at_least_32_chars_long_random_string

# "0" disables the in-process cron that fires scheduled playbooks.
JOB_SCHEDULER_ENABLED=1

# ── OAuth SSO (Generic OAuth / OIDC) ────────────────────────────────────────
# All login is done via a single OAuth 2.0 / OIDC provider.
# The provider must allow redirect_uri: https://<your-domain>/api/auth/oauth2/callback/<GENERIC_OAUTH_PROVIDER_ID>
#
# GENERIC_OAUTH_PROVIDER_ID  — arbitrary slug used in the callback URL (e.g. "keycloak", "sso")
# GENERIC_OAUTH_ISSUER       — OIDC issuer base URL (discovery URL appended automatically)
#                              e.g. https://keycloak.example.com/realms/myrealm
GENERIC_OAUTH_PROVIDER_ID=generic
GENERIC_OAUTH_CLIENT_ID=CHANGE_ME
GENERIC_OAUTH_CLIENT_SECRET=CHANGE_ME
GENERIC_OAUTH_ISSUER=https://CHANGE_ME

# ── Service-to-service auth ─────────────────────────────────────────────────
# Shared secret that the backend sends on internal /api/run/* calls and the
# ansible service compares against. Rotate together.
INTERNAL_TOKEN=CHANGE_ME_share_with_apps_ansible_env
