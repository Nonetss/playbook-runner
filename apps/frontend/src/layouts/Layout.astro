---
import "@/styles/global.css"
import { ClientRouter, fade } from "astro:transitions"
import { NavbarAuthenticated } from "@/components/features/global/navbar-authenticated"
import { NavbarGuest } from "@/components/features/global/navbar-guest"
import { Toaster } from "@/components/ui/sonner"

interface Props {
  title: string
  guestNavbar?: boolean
}

const navLinks = [
  { href: "/", label: "Inicio" },
  { href: "/credentials", label: "Credenciales" },
  { href: "/inventory", label: "Inventario" },
  { href: "/playbooks", label: "Playbooks" },
]

const { title, guestNavbar = false } = Astro.props

const { user, session } = Astro.locals
const hasSession = !!user && !!session
---

<html lang="es">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{title}</title>
    <ClientRouter />
    <script is:inline>
    function applyTheme() {
      const stored = localStorage.getItem("theme")
      const prefersDark = window.matchMedia(
        "(prefers-color-scheme: dark)"
      ).matches
      const theme = stored ?? (prefersDark ? "dark" : "light")
      document.documentElement.classList.toggle("dark", theme === "dark")
    }
    applyTheme()
    document.addEventListener("astro:after-swap", applyTheme)
    </script>
    <link rel="icon" href="/logo.webp" type="image/webp">
  </head>
  <body class="flex min-h-screen flex-col">
    {guestNavbar || !hasSession ? (
        <NavbarGuest client:load transition:persist nameApp="NONE.STACK"  />
      ) : (
        <NavbarAuthenticated
          client:load
          transition:persist
          user={user}
          session={session}
          nameApp="NONE.STACK"
          currentPath={Astro.url.pathname}
          navLinks={navLinks}
        />
      )}
    <div
      class="flex flex-1 flex-col"
      transition:animate={fade({ duration: "0.2s" })}
    >
      <slot />
    </div>
    <Toaster client:load transition:persist />
  </body>
</html>
