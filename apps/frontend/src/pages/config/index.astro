---
import { ConfigPage } from "@/components/features/config/components/config-page"
import Layout from "@/layouts/Layout.astro"
import { getServerT } from "@/lib/i18n/server"

const { locale } = Astro.locals
const t = await getServerT(locale, "config")
---

<Layout title={t("page.title")}>
  <ConfigPage client:only="react" />
</Layout>
