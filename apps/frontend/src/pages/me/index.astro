---
import { ProfilePage } from "@/components/features/me"
import Layout from "@/layouts/Layout.astro"
import { getServerT } from "@/lib/i18n/server"

const { user, session, locale } = Astro.locals

if (!user || !session) return Astro.redirect("/login")

const t = await getServerT(locale, "account")
---

<Layout title={t("profile.title")}>
  <ProfilePage user={user} session={session} locale={locale} client:only="react" />
</Layout>
