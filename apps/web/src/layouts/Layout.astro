---
import "@/styles/global.css"
import { Font } from "astro:assets"
import { ClientRouter } from "astro:transitions"
import { NavbarAuthenticated } from "@/components/features/global/navbar-authenticated"
import { NavbarGuest } from "@/components/features/global/navbar-guest"

interface NavLink {
  href: string
  label: string
}

interface Props {
  title: string
  navLinks?: NavLink[]
  /** Páginas públicas (login / registro): barra sin enlaces de la app ni ajustes. */
  guestNavbar?: boolean
}

const {
  title,
  guestNavbar = false,
  navLinks = [
    { href: "/", label: "Inicio" },
    { href: "/dashboard", label: "Dashboard" },
  ],
} = Astro.props

const { user, session } = Astro.locals
const hasSession = !!user && !!session
---

<html lang="es">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <Font cssVariable="--font-bricolage" />
    <Font cssVariable="--font-instrument" />
    <title>{title}</title>
    <ClientRouter />
    <script is:inline>
    function applyTheme() {
      const stored = localStorage.getItem("theme")
      const prefersDark = window.matchMedia(
        "(prefers-color-scheme: dark)"
      ).matches
      const theme = stored ?? (prefersDark ? "dark" : "dark")
      document.documentElement.classList.toggle("dark", theme === "dark")
    }
    applyTheme()
    document.addEventListener("astro:after-swap", applyTheme)
    </script>
    <link rel="icon" href="/logo.webp" type="image/webp">
  </head>
  <body class="flex min-h-screen flex-col">
    {guestNavbar || !hasSession ? (
        <NavbarGuest client:load nameApp="NONE.STACK" transition:persist />
      ) : (
        <NavbarAuthenticated
          client:load
          user={user}
          session={session}
          nameApp="NONE.STACK"
          currentPath={Astro.url.pathname}
          navLinks={navLinks}
          transition:persist
        />
      )}
    <slot />
  </body>
</html>
