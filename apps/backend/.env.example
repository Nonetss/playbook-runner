# ─────────────────────────────────────────────────────────────────────────────
# Backend environment variables (Hono + ORPC + Better Auth + Drizzle/Postgres)
# Copy this file to .env and fill in the values for your local environment.
# ─────────────────────────────────────────────────────────────────────────────

# Runtime mode: "development" | "production" | "test"
NODE_ENV=development

# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string used by Drizzle (packages/db).
# Example local: postgresql://postgres:postgres@localhost:5432/playbook_runner
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/playbook_runner

# ── Better Auth ──────────────────────────────────────────────────────────────
# Base URL of the auth server. In Docker compose this is http://backend:3000;
# for local dev it is http://localhost:3000.
BETTER_AUTH_URL=http://localhost:3000

# Secret used by Better Auth to sign sessions/cookies. MUST be at least 32 chars.
# Generate one with:  openssl rand -base64 48
BETTER_AUTH_SECRET=replace-me-with-a-long-random-string-of-at-least-32-chars

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed to call the API. Used by Hono's cors()
# middleware. For local dev, set this to the frontend URL.
CORS_ORIGIN=http://localhost:4321

# ── Optional ─────────────────────────────────────────────────────────────────
# Set to "1" to skip Zod env validation during build/CLI tasks.
# SKIP_ENV_VALIDATION=1

# ── OAuth SSO (Generic OAuth / OIDC) ────────────────────────────────────────
# Redirect URI en el IdP: {BETTER_AUTH_URL}/api/auth/oauth2/callback/{GENERIC_OAUTH_PROVIDER_ID}
# Debe coincidir con PUBLIC_GENERIC_OAUTH_PROVIDER_ID en el frontend.
# All three are optional: if any is missing, the SSO plugin is not loaded
# and only email/password sign-in is available.
GENERIC_OAUTH_PROVIDER_ID=generic
GENERIC_OAUTH_CLIENT_ID=CHANGE_ME
GENERIC_OAUTH_CLIENT_SECRET=CHANGE_ME
GENERIC_OAUTH_ISSUER=https://CHANGE_ME/realms/master

# ── Seed (initial admin user) ───────────────────────────────────────────────
# Used by `bun run db:seed`. The user is only created if it does not
# already exist. Defaults are shown below for local dev convenience;
# change them in any non-local environment.
SEED_ADMIN_EMAIL=admin@playbook-runner.local
SEED_ADMIN_PASSWORD=admin1234
SEED_ADMIN_NAME=Admin
