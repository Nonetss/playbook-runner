{
  "name": "backend",
  "type": "module",
  "main": "src/index.ts",
  "imports": {
    "#*": "./src/*.ts"
  },
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/index.mjs",
    "db:seed": "bun run src/scripts/seed.ts"
  },
  "dependencies": {
    "@orpc/openapi": "catalog:",
    "@orpc/server": "catalog:",
    "@orpc/zod": "catalog:",
    "@playbook-runner/api": "workspace:*",
    "@playbook-runner/auth": "workspace:*",
    "@playbook-runner/db": "workspace:*",
    "@playbook-runner/env": "workspace:*",
    "@playbook-runner/logger": "workspace:*",
    "drizzle-orm": "catalog:",
    "hono": "catalog:",
    "pg": "catalog:"
  },
  "devDependencies": {
    "@playbook-runner/config": "workspace:*",
    "@types/bun": "catalog:",
    "@types/pg": "catalog:",
    "tsdown": "^0.21.9",
    "typescript": "catalog:"
  }
}
